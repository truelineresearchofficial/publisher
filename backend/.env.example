# Copy to backend/.env on the server (chmod 600). Never commit the real file.
APP_ENV=production
SITE_NAME=publisher
LOG_LEVEL=INFO

# --- Postgres ---
# `db` service reads POSTGRES_*; the api reads DATABASE_URL (host = compose service `db`)
POSTGRES_USER=trl_publisher
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=trueline_publisher
DATABASE_URL=postgresql+asyncpg://trl_publisher:CHANGE_ME@db:5432/trueline_publisher

# --- Google Sheets (read-only view for sales/marketing) ---
SHEETS_SYNC_ENABLED=true
GOOGLE_SA_JSON_PATH=/run/secrets/google_sa.json
SHEETS_DOC_ID=
RECONCILER_INTERVAL_SECONDS=60
SYNC_MAX_ATTEMPTS=8

# --- anti-abuse ---
RATE_LIMIT_SUBMIT=10/minute
RATE_LIMIT_NEWSLETTER=5/minute
MAX_BODY_BYTES=32768
TRUSTED_PROXY_IPS=127.0.0.1
